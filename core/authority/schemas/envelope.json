{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Weaver Authority Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_id",
    "issuer",
    "subject",
    "claim",
    "evidence_level",
    "nonce",
    "issued_at",
    "payload",
    "payload_hash"
  ],
  "properties": {
    "envelope_id": {
      "type": "string",
      "minLength": 1
    },
    "issuer": {
      "type": "string",
      "minLength": 1
    },
    "subject": {
      "type": "string",
      "minLength": 1
    },
    "claim": {
      "type": "string",
      "minLength": 1
    },
    "evidence_level": {
      "enum": ["E0", "E1", "E2", "E3", "E4", "E5", "E6"]
    },
    "nonce": {
      "type": "string",
      "minLength": 8
    },
    "issued_at": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object"
    },
    "payload_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
